design:
  theme: sb2nov
  page:
    top_margin: 0.5in
    bottom_margin: 0.5in
    left_margin: 0.5in
    right_margin: 0.5in
    show_footer: false
  typography:
    font_size:
      name: 11pt
      body: 10pt
      section_titles: 12pt
    line_spacing: 0.5em
  section_titles:
    space_above: 0.3cm
    space_below: 0.2cm
  sections:
    space_between_regular_entries: 0.2cm
  header:
    space_below_name: 0.2cm
    space_below_headline: 0.2cm
    space_below_connections: 0.2cm
  entries:
    side_space: 0cm
settings:
  render_command:
    pdf_path: "rendercv_output/john_doe_cv.pdf"
    png_path: "rendercv_output/john_doe_cv.png"
